# App environment
ENVIRONMENT=prod
APP_PORT=8000

# CORS (optional; if frontend and backend share the same domain, can be omitted)
# CORS_ALLOW_ORIGINS=https://your-domain.railway.app

# Docker database: PostgreSQL is the primary storage in docker-compose.yml.
POSTGRES_DB=apteka
POSTGRES_USER=apteka
POSTGRES_PASSWORD=apteka
POSTGRES_PORT=5432
DATABASE_URL=postgresql://apteka:apteka@postgres:5432/apteka

# Docker Redis. Jobs/cache/locks are not moved to Redis yet, but the URL is available in app settings.
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# External API: ph.center
# You can paste either full value with Bearer prefix or token only.
PHCENTER_TOKEN=
PHCENTER_BASE_URL=https://ph.center

# External API: Provisor
PROVISOR_BASE_URL=https://api.provisor.kz
PROVISOR_LOGIN=
PROVISOR_PASSWORD=
PROVISOR_PRICE_TOTAL_TIMEOUT_SECONDS=45
PROVISOR_PRICE_READ_TIMEOUT_SECONDS=30
PROVISOR_PRICE_CONNECT_TIMEOUT_SECONDS=10
PROVISOR_EXCLUDED_FILIAL_IDS=1052,1076,1106,1107,1108,1111,1114,1149,1049
PROVISOR_AUTO_REFRESH_ENABLED=false
PROVISOR_AUTO_REFRESH_CRON="0 2 * * *"
PROVISOR_AUTO_REFRESH_MODE="selected"
PROVISOR_AUTO_REFRESH_MAX_PARALLEL_ACCOUNTS=2
PROVISOR_AUTO_REFRESH_MAX_PARALLEL_PLK=1
PROVISOR_AUTO_REFRESH_KEEP_LAST_SUCCESS=true
PROVISOR_AUTO_REFRESH_TIMEZONE=Asia/Qyzylorda

# External API: Vidman
VIDMAN_BASE_URL=https://1.provizor.kz
VIDMAN_LOGIN_PATH=/pages/login
VIDMAN_PRICE_BASE_URL=https://prv.kz
PRICE_SOURCE_SECRET=
